{
  "name": "lotr-chars",
  "version": "1.0.0",
  "description": "A CAP Node.js app for Lord of the Rings characters",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "sqlite3": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        }
      }
    }
  }
}
